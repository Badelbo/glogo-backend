# ── SERVER ──────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── DATABASE (PostgreSQL) ────────────────────────────────
DATABASE_URL=postgresql://glogo_user:password@localhost:5432/glogo_db
# OR individual fields:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=glogo_db
DB_USER=glogo_user
DB_PASSWORD=your_password

# ── REDIS ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=GlogoGhanaSecretKey_ChangeThis_2024!
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=GlogoRefreshSecret_ChangeThis_2024!
JWT_REFRESH_EXPIRES_IN=30d

# ── MTN MOBILE MONEY ────────────────────────────────────
MTN_MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_PRIMARY_KEY=your_mtn_primary_key
MTN_MOMO_API_USER=your_api_user_uuid
MTN_MOMO_API_KEY=your_api_key
MTN_MOMO_ENVIRONMENT=sandbox

# ── AIRTEL MONEY ─────────────────────────────────────────
AIRTEL_BASE_URL=https://openapi.airtel.africa
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_COUNTRY=GH
AIRTEL_CURRENCY=GHS

# ── FIREBASE (Push Notifications) ───────────────────────
FIREBASE_PROJECT_ID=glogo-ghana
FIREBASE_PRIVATE_KEY=your_firebase_private_key
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@glogo-ghana.iam.gserviceaccount.com

# ── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
